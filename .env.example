# Core
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
CONFIG_PATH=configs/default.yaml

# Local paths
MODELS_ROOT=/mnt/PRO6000_disk/models
DATA_ROOT=/mnt/PRO6000_disk/data

# RAG
VECTOR_BACKEND=local
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=ai_fullstack_docs
EMBEDDING_MODEL_PATH=/mnt/PRO6000_disk/models/BAAI

# OpenAI-compatible LLM/VLM endpoint, optional
OPENAI_BASE_URL=http://127.0.0.1:8001/v1
OPENAI_API_KEY=EMPTY
LLM_MODEL=qwen-local
VLM_MODEL=llava-local

# YOLO
YOLO_MODEL_PATH=weights/yolov8n.pt
YOLO_DEVICE=0

# GUI Agent
GUI_AGENT_DRY_RUN=true
